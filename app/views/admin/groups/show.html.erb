<% content_for :title, @group.name %>

<div class="page">
  <div class="page__header">
    <div class="page__header-actions">
      <%= link_to "편집", edit_admin_group_path(@group), class: "btn btn--secondary btn--sm" %>
      <%= link_to admin_groups_path, class: "btn btn--ghost btn--sm" do %>
        <iconify-icon icon="lucide:arrow-left"></iconify-icon> 목록
      <% end %>
    </div>
  </div>

  <div class="admin-info">
    <p><strong>소유자:</strong> <%= @group.owner.nickname %> (<%= @group.owner.email_address %>)</p>
    <p><strong>생성일:</strong> <%= @group.created_at.strftime("%Y-%m-%d %H:%M") %></p>
  </div>

  <h2 class="section-title">멤버 (<%= @members.size %>명)</h2>
  <% if @members.any? %>
    <table class="admin-table">
      <thead>
        <tr>
          <th>닉네임</th>
          <th>이메일</th>
          <th>역할</th>
        </tr>
      </thead>
      <tbody>
        <% @members.each do |user| %>
          <% membership = @group.group_memberships.find { |m| m.user_id == user.id } %>
          <tr>
            <td><%= link_to user.nickname, admin_user_path(user) %></td>
            <td class="admin-table__mono"><%= user.email_address %></td>
            <td>
              <% if membership&.owner? %>
                <span class="admin-badge admin-badge--admin">소유자</span>
              <% else %>
                <span class="admin-badge">멤버</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="empty-state">멤버가 없습니다.</p>
  <% end %>
</div>
