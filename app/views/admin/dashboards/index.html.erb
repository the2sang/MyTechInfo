<% content_for :title, "관리자 대시보드" %>

<div class="page">
  <div class="page__header">
    <h1 class="title-collage" aria-label="Admin">
      <span class="tc-letter tc-1">A</span><span class="tc-letter tc-2">d</span><span class="tc-letter tc-3">m</span><span class="tc-letter tc-4">i</span><span class="tc-letter tc-5">n</span>
    </h1>
    <div class="page__header-actions">
      <%= link_to admin_users_path, class: "btn btn--secondary btn--sm" do %>
        <i class="fa-solid fa-users"></i> 회원
      <% end %>
      <%= link_to admin_sessions_path, class: "btn btn--secondary btn--sm" do %>
        <i class="fa-solid fa-clock-rotate-left"></i> 접속이력
      <% end %>
    </div>
  </div>

  <div class="admin-stats">
    <div class="admin-stats__card">
      <div class="admin-stats__label">전체 회원</div>
      <div class="admin-stats__value"><%= number_with_delimiter(@user_count) %></div>
    </div>
    <div class="admin-stats__card">
      <div class="admin-stats__label">관리자</div>
      <div class="admin-stats__value"><%= @admin_count %></div>
    </div>
    <div class="admin-stats__card">
      <div class="admin-stats__label">신규 (7일)</div>
      <div class="admin-stats__value"><%= @new_users_this_week %></div>
    </div>
    <div class="admin-stats__card">
      <div class="admin-stats__label">접속 (24h)</div>
      <div class="admin-stats__value"><%= @sessions_today %></div>
    </div>
  </div>

  <div class="admin-grid">
    <section class="admin-panel">
      <div class="admin-panel__header">
        <h2 class="admin-panel__title">최근 가입</h2>
        <%= link_to "전체 보기", admin_users_path, class: "admin-panel__link" %>
      </div>
      <% if @recent_users.any? %>
        <table class="admin-table">
          <thead>
            <tr>
              <th>닉네임</th>
              <th>이메일</th>
              <th>권한</th>
              <th>가입일</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_users.each do |user| %>
              <tr>
                <td><%= link_to user.nickname, admin_user_path(user) %></td>
                <td class="admin-table__mono"><%= user.email_address %></td>
                <td>
                  <% if user.admin? %>
                    <span class="admin-badge admin-badge--admin">ADMIN</span>
                  <% else %>
                    <span class="admin-badge">USER</span>
                  <% end %>
                </td>
                <td><%= user.created_at.strftime("%Y-%m-%d") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="empty-state">데이터가 없습니다.</p>
      <% end %>
    </section>

    <section class="admin-panel">
      <div class="admin-panel__header">
        <h2 class="admin-panel__title">최근 접속</h2>
        <%= link_to "전체 보기", admin_sessions_path, class: "admin-panel__link" %>
      </div>
      <% if @recent_sessions.any? %>
        <table class="admin-table">
          <thead>
            <tr>
              <th>사용자</th>
              <th>IP</th>
              <th>UA</th>
              <th>시각</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_sessions.each do |session| %>
              <tr>
                <td><%= link_to session.user.nickname, admin_user_path(session.user) %></td>
                <td class="admin-table__mono"><%= session.ip_address %></td>
                <td class="admin-table__truncate" title="<%= session.user_agent %>"><%= session.user_agent %></td>
                <td><%= session.created_at.strftime("%Y-%m-%d %H:%M") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="empty-state">데이터가 없습니다.</p>
      <% end %>
    </section>
  </div>
</div>
