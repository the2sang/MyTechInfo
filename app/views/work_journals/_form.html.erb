<%= form_with model: work_journal, class: "form work-journal-form" do |f| %>

  <% if work_journal.errors.any? %>
    <div class="form__errors">
      <p class="form__errors-title">입력 오류가 있습니다</p>
      <ul class="form__errors-list">
        <% work_journal.errors.each do |e| %>
          <li><%= e.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form__field">
    <%= f.label :title, "제목", class: "form__label" %>
    <%= f.text_field :title,
          class: "form__input",
          placeholder: "한 줄 요약",
          maxlength: 200,
          required: true,
          autofocus: true %>
  </div>

  <div class="form__field">
    <%= f.label :work_date, "업무 수행일", class: "form__label" %>
    <%= f.date_field :work_date, class: "form__input", required: true %>
  </div>

  <div class="form__row">
    <div class="form__field">
      <%= f.label :category, "카테고리", class: "form__label" %>
      <%= f.select :category,
            WorkJournal.categories.keys.map { |k| [ t("work_journals.category.#{k}"), k ] },
            {},
            class: "form__input" %>
    </div>

    <div class="form__field">
      <%= f.label :status, "상태", class: "form__label" %>
      <%= f.select :status,
            WorkJournal.statuses.keys.map { |k| [ t("work_journals.status.#{k}"), k ] },
            {},
            class: "form__input" %>
    </div>
  </div>

  <div class="form__field">
    <div class="work-journal-progress" data-controller="range" data-range-suffix-value="%">
      <div class="work-journal-progress__header">
        <%= f.label :progress, "진행률", class: "form__label" %>
        <span class="work-journal-progress__value"
              data-range-target="display"><%= work_journal.progress || 0 %>%</span>
      </div>
      <%= f.range_field :progress,
            min: 0, max: 100, step: 5,
            class: "work-journal-progress__slider",
            data: { action: "input->range#update" } %>
      <div class="work-journal-progress__scale"><span>0%</span><span>100%</span></div>
    </div>
  </div>

  <div class="form__field">
    <%= f.label :content, "상세 내용 (Markdown 지원)", class: "form__label" %>
    <%= f.text_area :content,
          class: "form__textarea",
          rows: 14,
          required: true,
          placeholder: "## 진행\n- ..." %>
    <%= f.hidden_field :content_format, value: "markdown" %>
  </div>

  <div class="form__actions">
    <%= f.submit work_journal.new_record? ? "등록" : "수정", class: "btn btn--primary" %>
    <%= link_to "취소", work_journals_path, class: "btn btn--ghost" %>
  </div>
<% end %>
