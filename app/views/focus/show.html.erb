<% content_for :title, "집중" %>

<div class="page page--focus"
     data-controller="pomodoro"
     data-pomodoro-focus-minutes-value="<%= @setting.focus_minutes %>"
     data-pomodoro-break-minutes-value="<%= @setting.break_minutes %>"
     data-pomodoro-long-break-minutes-value="<%= @setting.long_break_minutes %>"
     data-pomodoro-rounds-value="<%= @setting.rounds %>"
     data-pomodoro-auto-start-value="<%= @setting.auto_start %>">

  <div class="pomodoro-header">
    <%= link_to focus_settings_path, class: "pomodoro-header__settings", title: "설정" do %>
      <i class="fa-solid fa-gear"></i>
    <% end %>
  </div>

  <div class="pomodoro-mode">
    <span class="pomodoro-mode__label" data-pomodoro-target="modeLabel" data-mode="focus">집중</span>
    <span class="pomodoro-mode__sessions" data-pomodoro-target="sessionCount">완료 0세션</span>
  </div>

  <div class="pomodoro-timer">
    <span class="pomodoro-timer__display" data-pomodoro-target="display">
      <%= "%02d:00" % @setting.focus_minutes %>
    </span>
  </div>

  <div class="pomodoro-controls">
    <button class="btn btn--primary pomodoro-controls__start"
            data-pomodoro-target="startBtn"
            data-action="click->pomodoro#toggle">
      시작
    </button>
    <button class="btn btn--ghost" data-action="click->pomodoro#reset" title="리셋">
      <i class="fa-solid fa-rotate-left"></i>
    </button>
    <button class="btn btn--ghost" data-action="click->pomodoro#skipMode" title="모드 전환">
      <i class="fa-solid fa-forward-step"></i>
    </button>
  </div>

  <div class="pomodoro-rounds">
    <% @setting.rounds.times do |i| %>
      <span class="pomodoro-rounds__dot" data-pomodoro-target="roundDot"></span>
    <% end %>
  </div>

  <%# ── Turtle track ─────────────────────────────────────── %>
  <div class="turtle-track">
    <div class="turtle-track__road">
      <div class="turtle-track__fill" data-pomodoro-target="turtleFill"></div>
      <span class="turtle-track__turtle" data-pomodoro-target="turtle">🐢</span>
    </div>
    <span class="turtle-track__flag">🏁</span>
  </div>
</div>
