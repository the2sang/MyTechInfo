<% content_for :title, @tech_info.title %>

<div class="page page--editor">
  <%= link_to "기술정보 목록", tech_infos_path, class: "back-link" %>

  <div class="tech-detail">
    <div class="tech-detail__header">
      <h3 class="tech-detail__title"><%= @tech_info.title %></h3>
      <div class="tech-detail__stars">
        <%= render "stars", usefulness: @tech_info.usefulness %>
      </div>
      <span class="badge badge--<%= @tech_info.is_public? ? 'public' : 'private' %>">
        <%= @tech_info.is_public? ? "공개" : "비공개" %>
      </span>
    </div>

    <% if @tech_info.related_tech_list.any? %>
      <div class="tech-detail__tags">
        <% @tech_info.related_tech_list.each do |tag| %>
          <span class="tech-tag"><%= tag %></span>
        <% end %>
      </div>
    <% end %>

    <div class="tech-detail__meta">
      <span><%= @tech_info.user.nickname %></span>
      <span>&middot;</span>
      <span><%= @tech_info.created_at.strftime("%Y년 %m월 %d일") %></span>
    </div>

    <%= render "reactions",
          tech_info: @tech_info,
          current_user: authenticated? ? Current.session.user : nil %>

    <% if @tech_info.reference_url.present? %>
      <div class="tech-detail__section">
        <div class="tech-detail__label">참고 URL</div>
        <div class="tech-detail__value">
          <%= link_to @tech_info.reference_url, @tech_info.reference_url, target: "_blank", rel: "noopener noreferrer" %>
        </div>
      </div>
    <% end %>

    <div class="tech-detail__section">
      <div class="tech-detail__label">
        상세 내용
        <span class="tech-detail__format-badge tech-detail__format-badge--<%= @tech_info.content_format %>">
          <%= @tech_info.content_format&.upcase %>
        </span>
      </div>
      <% tech_content = render_tech_content(@tech_info) %>
      <% if tech_content.present? %>
        <div class="tech-detail__value tech-detail__value--rendered <%= @tech_info.content_format == 'html' ? 'lexxy-content' : 'prose' %>">
          <%= tech_content %>
        </div>
      <% else %>
        <p class="tech-detail__empty">내용이 없습니다.</p>
      <% end %>
    </div>

    <% if @tech_info.extra_info.present? %>
      <div class="tech-detail__section">
        <div class="tech-detail__label">부가 정보</div>
        <div class="tech-detail__value tech-detail__value--content"><%= simple_format(@tech_info.extra_info) %></div>
      </div>
    <% end %>
  </div>

  <% if authenticated? && Current.session&.user == @tech_info.user %>
    <div class="form__actions" style="margin-top:24px;">
      <%= link_to "수정", edit_tech_info_path(@tech_info), class: "btn btn--secondary" %>
      <%= button_to "삭제", @tech_info, method: :delete,
          class: "btn btn--danger",
          form: { data: { turbo_confirm: "이 기술정보를 삭제하시겠습니까?" } } %>
    </div>
  <% end %>

  <%# Comments section %>
  <div class="comments">
    <h2 class="comments__title">댓글 <span class="comments__count"><%= @tech_info.comments.count %></span></h2>

    <% if @tech_info.comments.any? %>
      <div class="comment-list">
        <% @tech_info.comments.includes(:user).oldest.each do |comment| %>
          <div class="comment">
            <div class="comment__header">
              <div class="comment__avatar"><%= comment.user.nickname.first.upcase %></div>
              <div class="comment__meta">
                <span class="comment__author"><%= comment.user.nickname %></span>
                <span class="comment__date"><%= comment.created_at.strftime("%Y.%m.%d %H:%M") %></span>
              </div>
              <% if authenticated? && Current.session&.user == comment.user %>
                <%= button_to "삭제", tech_info_comment_path(@tech_info, comment), method: :delete,
                    class: "comment__delete",
                    form: { data: { turbo_confirm: "댓글을 삭제하시겠습니까?" } } %>
              <% end %>
            </div>
            <div class="comment__body"><%= simple_format(comment.body) %></div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="comments__empty">아직 댓글이 없습니다. 첫 번째 댓글을 남겨보세요.</p>
    <% end %>

    <% if authenticated? %>
      <div class="comment-form">
        <%= form_with url: tech_info_comments_path(@tech_info), scope: :comment, class: "form" do |form| %>
          <div class="form__field">
            <%= form.label :body, "댓글 작성", class: "form__label" %>
            <%= form.textarea :body, class: "form__textarea comment-form__textarea",
                placeholder: "댓글을 입력하세요 (최대 1000자)", maxlength: 1000, rows: 3 %>
          </div>
          <div class="form__actions">
            <%= form.submit "댓글 등록", class: "btn btn--primary" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="comments__login-prompt">
        댓글을 작성하려면 <%= link_to "로그인", new_session_path %>하세요.
      </p>
    <% end %>
  </div>
</div>
