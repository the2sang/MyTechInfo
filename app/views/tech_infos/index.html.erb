<% content_for :title, "기술정보" %>

<div class="page" data-controller="export-select">
  <div class="page__header">
    <h1 class="page__title">기술정보</h1>
    <% if authenticated? %>
      <div class="page__header-actions">
        <%= link_to "새 기술정보", new_tech_info_path, class: "btn btn--primary" %>
        <button hidden
                class="btn btn--secondary"
                data-export-select-target="exportBtn"
                data-base-url="<%= export_tech_infos_path %>"
                data-action="click->export-select#exportSelected">
          <i class="fa-solid fa-file-export"></i>
          선택 Export (<span data-export-select-target="count">0</span>)
        </button>
        <%= link_to export_tech_infos_path, class: "btn btn--secondary" do %>
          <i class="fa-solid fa-download"></i> Export JSON
        <% end %>
        <%= form_with url: import_tech_infos_path, multipart: true, class: "import-form",
                      data: { controller: "import-form" } do |f| %>
          <%= f.label :import_file, class: "btn btn--ghost import-form__label" do %>
            <i class="fa-solid fa-upload"></i> Import JSON
          <% end %>
          <%= f.file_field :import_file, accept: ".json", class: "import-form__file",
                           data: { action: "change->import-form#submit" } %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @tech_infos.empty? %>
    <div class="empty-state">
      <p class="empty-state__text">등록된 기술정보가 없습니다.</p>
    </div>
  <% else %>
    <div class="tech-info-list">
      <% @tech_infos.each do |tech_info| %>
        <div class="tech-info-card" data-tech-info-id="<%= tech_info.id %>">
          <div class="tech-info-card__header">
            <div class="tech-info-card__title">
              <%= link_to tech_info.title, tech_info %>
            </div>
            <div class="tech-info-card__right">
              <div class="tech-info-card__stars">
                <%= render "tech_infos/stars", usefulness: tech_info.usefulness %>
              </div>
              <% if authenticated? %>
                <button class="export-toggle-btn"
                        title="익스포트 선택"
                        data-action="click->export-select#toggle">
                  <i class="fa-regular fa-square"></i>
                </button>
              <% end %>
            </div>
          </div>

          <% if tech_info.related_tech_list.any? %>
            <div class="tech-info-card__tags">
              <% tech_info.related_tech_list.each do |tag| %>
                <span class="tech-tag"><%= tag %></span>
              <% end %>
            </div>
          <% end %>

          <div class="tech-info-card__meta">
            <span><%= tech_info.user.email_address %></span>
            <span>&middot;</span>
            <span><%= tech_info.created_at.strftime("%Y.%m.%d") %></span>
          </div>
        </div>
      <% end %>
    </div>

    <div class="pagination">
      <div class="pagination__info">
        <%= @total %>건 중 <%= [(@page - 1) * 5 + 1, @total].min %>–<%= [@page * 5, @total].min %>
      </div>
      <div class="pagination__nav">
        <% if @page > 1 %>
          <%= link_to "← 이전", tech_infos_path(page: @page - 1), class: "btn btn--secondary" %>
        <% else %>
          <span class="btn btn--secondary btn--disabled">← 이전</span>
        <% end %>
        <span class="pagination__pages"><%= @page %> / <%= @total_pages %></span>
        <% if @page < @total_pages %>
          <%= link_to "다음 →", tech_infos_path(page: @page + 1), class: "btn btn--secondary" %>
        <% else %>
          <span class="btn btn--secondary btn--disabled">다음 →</span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
