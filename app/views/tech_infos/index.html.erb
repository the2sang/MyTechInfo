<% content_for :title, "Tech Info" %>

<div class="page" data-controller="export-select">
  <div class="page__header">
    <h1 class="title-collage" aria-label="Tech Info">
      <span class="tc-letter tc-1">T</span><span class="tc-letter tc-2">e</span><span class="tc-letter tc-3">c</span><span class="tc-letter tc-4">h</span><span class="tc-word-gap"></span><span class="tc-letter tc-5">I</span><span class="tc-letter tc-6">n</span><span class="tc-letter tc-7">f</span><span class="tc-letter tc-8">o</span>
    </h1>
    <% if authenticated? %>
      <div class="page__header-actions">
        <%= link_to "New", new_tech_info_path, class: "btn btn--primary" %>
        <button hidden
                class="btn btn--secondary"
                data-export-select-target="exportBtn"
                data-base-url="<%= export_tech_infos_path %>"
                data-action="click->export-select#exportSelected">
          <iconify-icon icon="lucide:file-output"></iconify-icon>
          선택 Exp <span data-export-select-target="count">0</span>
        </button>
        <%= link_to export_tech_infos_path, class: "btn btn--secondary" do %>
          <iconify-icon icon="lucide:download"></iconify-icon> Exp JSON
        <% end %>
        <%= form_with url: import_tech_infos_path, multipart: true, class: "import-form",
                      data: { controller: "import-form" } do |f| %>
          <%= f.label :import_file, class: "btn btn--secondary import-form__label" do %>
            <iconify-icon icon="lucide:upload"></iconify-icon> Imp JSON
          <% end %>
          <%= f.file_field :import_file, accept: ".json", class: "import-form__file",
                           data: { action: "change->import-form#submit" } %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%= render "shared/search_form",
        form_url: tech_infos_path,
        reset_url: tech_infos_path,
        content_placeholder: "제목 또는 내용 검색",
        search_query: @search_query,
        date_from: @search_date_from,
        date_to: @search_date_to,
        total: @total,
        default_type: "date" %>

  <% if @tech_infos.empty? %>
    <div class="empty-state">
      <p class="empty-state__text">등록된 기술정보가 없습니다.</p>
    </div>
  <% else %>
    <div class="tech-info-list">
      <% @tech_infos.each do |tech_info| %>
        <div class="tech-info-card" data-tech-info-id="<%= tech_info.id %>">
          <div class="tech-info-card__title">
            <%= link_to tech_info, class: "tech-info-card__title-link" do %>
              <%= highlight_search(tech_info.title, @search_query) %>
            <% end %>
          </div>

          <% if tech_info.related_tech_list.any? %>
            <div class="tech-info-card__tags">
              <% tech_info.related_tech_list.each do |tag| %>
                <span class="tech-tag tech-tag--sm"><%= tag %></span>
              <% end %>
            </div>
          <% end %>

          <div class="tech-info-card__footer">
            <div class="tech-info-card__meta">
              <span><%= tech_info.user.nickname %></span>
              <span>&middot;</span>
              <span><%= tech_info.created_at.strftime("%Y.%m.%d") %></span>
            </div>
            <div class="tech-info-card__controls">
              <div class="tech-info-card__stars">
                <%= render "tech_infos/stars", usefulness: tech_info.usefulness %>
              </div>
              <span class="badge badge--<%= tech_info.is_public? ? 'public' : 'private' %>">
                <%= tech_info.is_public? ? "공개" : "비공개" %>
              </span>
              <% if authenticated? %>
                <button class="export-toggle-btn"
                        title="익스포트 선택"
                        data-action="click->export-select#toggle">
                  <iconify-icon icon="lucide:square"></iconify-icon>
                </button>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="pagination">
      <div class="pagination__info">
        <%= @total %>건 중 <%= [(@page - 1) * 10 + 1, @total].min %>–<%= [@page * 10, @total].min %>
      </div>
      <div class="pagination__nav">
        <% sp = { q: @search_query, date_from: @search_date_from, date_to: @search_date_to }.reject { |_, v| v.blank? } %>
        <% if @page > 1 %>
          <%= link_to "← 이전", tech_infos_path(sp.merge(page: @page - 1)), class: "btn btn--secondary" %>
        <% else %>
          <span class="btn btn--secondary btn--disabled">← 이전</span>
        <% end %>
        <span class="pagination__pages"><%= @page %> / <%= [@total_pages, 1].max %></span>
        <% if @page < @total_pages %>
          <%= link_to "다음 →", tech_infos_path(sp.merge(page: @page + 1)), class: "btn btn--secondary" %>
        <% else %>
          <span class="btn btn--secondary btn--disabled">다음 →</span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
