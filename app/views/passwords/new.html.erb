<% content_for :title, "Forgot Password" %>

<div class="page page--narrow">
  <div class="auth-card">
    <div class="auth-card__header">
      <h1 class="page__title">Reset password</h1>
      <p style="font-size:13px;color:var(--color-text-muted);margin-top:6px;">
        Enter your email and we'll send reset instructions.
      </p>
    </div>

    <%= form_with url: passwords_path, class: "form" do |form| %>
      <div class="form__field">
        <%= form.label :email_address, "Email address", class: "form__label" %>
        <%= form.email_field :email_address, class: "form__input",
            placeholder: "you@example.com",
            autocomplete: "email",
            autofocus: true,
            value: params[:email_address] %>
      </div>

      <div class="form__actions" style="flex-direction:column;gap:12px;">
        <%= form.submit "Send reset instructions", class: "btn btn--primary", style: "width:100%;justify-content:center;" %>
        <p style="font-size:12px;color:var(--color-text-muted);text-align:center;">
          Remember your password? <%= link_to "Sign in", new_session_path %>
        </p>
      </div>
    <% end %>
  </div>
</div>
