<% content_for :title, "Update Password" %>

<div class="page page--narrow">
  <div class="auth-card">
    <div class="auth-card__header">
      <h1 class="page__title">Update password</h1>
      <p style="font-size:13px;color:var(--color-text-muted);margin-top:6px;">Choose a strong new password.</p>
    </div>

    <%= form_with url: password_path(params[:token]), method: :put, class: "form" do |form| %>
      <div class="form__field">
        <%= form.label :password, "New password", class: "form__label" %>
        <%= form.password_field :password, class: "form__input",
            placeholder: "Minimum 8 characters",
            autocomplete: "new-password",
            maxlength: 72 %>
      </div>

      <div class="form__field">
        <%= form.label :password_confirmation, "Confirm new password", class: "form__label" %>
        <%= form.password_field :password_confirmation, class: "form__input",
            placeholder: "Repeat new password",
            autocomplete: "new-password",
            maxlength: 72 %>
      </div>

      <div class="form__actions">
        <%= form.submit "Update password", class: "btn btn--primary" %>
        <%= link_to "Cancel", new_session_path, class: "btn btn--ghost" %>
      </div>
    <% end %>
  </div>
</div>
