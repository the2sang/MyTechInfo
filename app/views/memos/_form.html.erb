<%= form_with model: memo, class: "memo-form" do |f| %>
  <% if memo.errors.any? %>
    <div class="form__errors">
      <ul class="form__errors-list">
        <% memo.errors.each do |e| %>
          <li><%= e.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form__field">
    <%= f.label :title, "제목", class: "form__label" %>
    <%= f.text_field :title, class: "form__input", placeholder: "메모 제목", maxlength: 100, autofocus: true %>
  </div>

  <div class="form__field">
    <%= f.label :content, "내용", class: "form__label" %>
    <%= f.textarea :content, class: "form__textarea memo-form__textarea",
        placeholder: "메모 내용을 입력하세요", maxlength: 2000, rows: 4 %>
  </div>

  <div class="form__actions">
    <%= f.submit memo.new_record? ? "등록" : "수정", class: "btn btn--primary btn--sm" %>
    <%= link_to "취소", memos_path, class: "btn btn--ghost btn--sm" %>
  </div>
<% end %>
