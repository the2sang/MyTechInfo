<!DOCTYPE html>
<html lang="ko">
  <head>
    <%= toast_css_variables %>

    <% site_identity = authenticated? ? Current.session.user.email_address.split("@").first : "Public" %>
    <title><%= authenticated? ? [content_for(:title), site_identity].compact_blank.join(" — ") : site_identity %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="MyTechInfo">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Ultra&family=Press+Start+2P&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="shortcut icon" href="/icon.svg">
    <link rel="manifest" href="/manifest.json">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="MyTechInfo">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "lexxy", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "faw_toast.min", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= javascript_include_tag "faw_toast.min", "data-turbo-track": "reload" %>
    <script>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/service-worker.js", { scope: "/" });
      }
    </script>
  </head>

  <body data-controller="pwa-install">
    <%# iOS 홈 화면 추가 안내 모달 (전역) %>
    <div class="pwa-ios-modal" data-pwa-install-target="iosModal" hidden>
      <div class="pwa-ios-modal__backdrop" data-action="click->pwa-install#hideIosModal"></div>
      <div class="pwa-ios-modal__box">
        <button class="pwa-ios-modal__close" data-action="click->pwa-install#hideIosModal" aria-label="닫기">
          <i class="fa-solid fa-xmark"></i>
        </button>
        <p class="pwa-ios-modal__title">
          <i class="fa-solid fa-mobile-screen-button"></i> 홈 화면에 추가 (iOS)
        </p>
        <ol class="pwa-ios-modal__steps">
          <li>하단 <strong>공유 버튼</strong> <i class="fa-solid fa-arrow-up-from-bracket"></i> 탭</li>
          <li><strong>홈 화면에 추가</strong> 선택</li>
          <li><strong>추가</strong> 버튼 탭</li>
        </ol>
        <p class="pwa-ios-modal__note">Safari 브라우저에서만 지원됩니다.</p>
      </div>
    </div>

    <nav class="nav">
      <div class="nav__inner">
        <div class="nav__left">
          <%= link_to root_path, class: "nav__logo" do %>
            <span class="nav__logo-mark">T</span>
            <span class="nav__logo-text nav-hide-mobile">
              <%= authenticated? ? Current.session.user.email_address.split("@").first : "Public" %>
            </span>
          <% end %>
          <% if content_for?(:title) %>
            <span class="nav__page-title nav-hide-mobile">— <%= content_for(:title) %></span>
          <% end %>
        </div>

        <div class="nav__menu">
          <%# Information %>
          <div class="nav__group"
               data-controller="nav-group"
               data-action="mouseenter->nav-group#hover mouseleave->nav-group#hoverOut">
            <button class="nav__group-btn"
                    data-action="click->nav-group#tap"
                    data-nav-group-target="trigger"
                    aria-expanded="false"
                    aria-haspopup="true">
              <span class="nav__group-label">Information</span>
              <i class="fa-solid fa-circle-info nav__group-icon"></i>
              <i class="fa-solid fa-chevron-down nav__group-chevron"></i>
            </button>
            <div class="nav__dropdown" data-nav-group-target="dropdown">
              <%= link_to tech_infos_path, class: "nav__dropdown-item" do %>
                <i class="fa-solid fa-database"></i><span>기술정보</span>
              <% end %>
              <%= link_to life_infos_path, class: "nav__dropdown-item" do %>
                <i class="fa-solid fa-seedling"></i><span>생활정보</span>
              <% end %>
              <%= link_to stock_infos_path, class: "nav__dropdown-item" do %>
                <i class="fa-solid fa-chart-line"></i><span>주식전망</span>
              <% end %>
              <%= link_to memos_path, class: "nav__dropdown-item" do %>
                <i class="fa-solid fa-note-sticky"></i><span>메모</span>
              <% end %>
            </div>
          </div>

          <%# Working (인증 필요) %>
          <% if authenticated? %>
            <div class="nav__group"
                 data-controller="nav-group"
                 data-action="mouseenter->nav-group#hover mouseleave->nav-group#hoverOut">
              <button class="nav__group-btn"
                      data-action="click->nav-group#tap"
                      data-nav-group-target="trigger"
                      aria-expanded="false"
                      aria-haspopup="true">
                <span class="nav__group-label">Working</span>
                <i class="fa-solid fa-list-check nav__group-icon"></i>
                <i class="fa-solid fa-chevron-down nav__group-chevron"></i>
              </button>
              <div class="nav__dropdown" data-nav-group-target="dropdown">
                <%= link_to work_plans_path, class: "nav__dropdown-item" do %>
                  <i class="fa-solid fa-calendar-check"></i><span>작업계획서</span>
                <% end %>
                <%= link_to work_journals_path, class: "nav__dropdown-item" do %>
                  <i class="fa-solid fa-pen-to-square"></i><span>업무일지</span>
                <% end %>
                <%= link_to manpower_records_path, class: "nav__dropdown-item" do %>
                  <i class="fa-solid fa-users-gear"></i><span>인력지원수행내역</span>
                <% end %>
              </div>
            </div>
          <% end %>

          <%# Utils %>
          <div class="nav__group"
               data-controller="nav-group"
               data-action="mouseenter->nav-group#hover mouseleave->nav-group#hoverOut">
            <button class="nav__group-btn"
                    data-action="click->nav-group#tap"
                    data-nav-group-target="trigger"
                    aria-expanded="false"
                    aria-haspopup="true">
              <span class="nav__group-label">Utils</span>
              <i class="fa-solid fa-wrench nav__group-icon"></i>
              <i class="fa-solid fa-chevron-down nav__group-chevron"></i>
            </button>
            <div class="nav__dropdown" data-nav-group-target="dropdown">
              <%= link_to focus_path, class: "nav__dropdown-item" do %>
                <i class="fa-solid fa-stopwatch"></i><span>포모도로</span>
              <% end %>
              <%= link_to puzzle_path, class: "nav__dropdown-item" do %>
                <i class="fa-solid fa-puzzle-piece"></i><span>퍼즐조각맞추기</span>
              <% end %>
            </div>
          </div>
        </div>

        <div class="nav__right">
          <div class="nav__search-wrapper" data-controller="nav-search">
            <button class="nav__icon-btn"
                    aria-label="검색 열기"
                    data-nav-search-target="toggle"
                    data-action="click->nav-search#open">
              <i class="fa-solid fa-magnifying-glass"></i>
            </button>
            <%= form_with url: tech_infos_path, method: :get, class: "nav-search",
                  data: { "nav-search-target": "form" } do |f| %>
              <i class="fa-solid fa-magnifying-glass nav-search__icon"></i>
              <%= f.text_field :q,
                  class: "nav-search__input",
                  placeholder: "기술정보 검색...",
                  value: params[:q],
                  autocomplete: "off",
                  data: { "nav-search-target": "input" } %>
              <span class="nav-search__hint"><kbd>⌘K</kbd></span>
            <% end %>
          </div>

          <% if current_user&.admin? %>
            <%= link_to admin_root_path, class: "nav__icon-btn nav__icon-btn--admin", title: "관리자" do %>
              <i class="fa-solid fa-shield-halved"></i>
            <% end %>
          <% end %>
          <a href="https://github.com/the2sang/MyTechInfo"
             class="nav__icon-btn nav-hide-xs" title="GitHub"
             target="_blank" rel="noopener noreferrer">
            <i class="fa-brands fa-github"></i>
          </a>

          <div class="nav__divider"></div>

          <% if authenticated? %>
            <span class="nav__nickname nav-hide-mobile"><%= Current.session.user.nickname %></span>
            <%= button_to session_path, method: :delete, class: "btn btn--logout btn--sm" do %>
              <i class="fa-solid fa-right-from-bracket nav-only-mobile"></i>
              <span class="nav-hide-mobile">Log out</span>
            <% end %>
          <% else %>
            <%= link_to new_session_path, class: "btn btn--secondary btn--sm" do %>
              <i class="fa-solid fa-right-to-bracket nav-only-mobile"></i>
              <span class="nav-hide-mobile">Log in</span>
            <% end %>
            <%= link_to new_registration_path, class: "btn btn--primary btn--sm" do %>
              <i class="fa-solid fa-user-plus nav-only-mobile"></i>
              <span class="nav-hide-mobile">Join</span>
            <% end %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="site-content" data-controller="header-collapse">
      <% if content_for?(:title) %>
        <h1 class="sr-only"><%= content_for(:title) %></h1>
      <% end %>
      <%= yield %>
    </main>

    <footer class="footer">
      <div class="footer__inner">
        <span class="footer__copy">&copy; <%= Time.current.year %> <%= site_identity %></span>
        <button class="footer__install-btn"
                data-pwa-install-target="footerBtn"
                data-action="click->pwa-install#install"
                aria-label="홈 화면에 추가">
          <i class="fa-solid fa-mobile-screen-button"></i>
          <span>홈 화면에 추가</span>
        </button>
      </div>
    </footer>
    <%= toast_container %>
  </body>
</html>
