<% content_for :title, "Sign In" %>

<div class="page page--narrow">
  <div class="auth-card">
    <div class="auth-card__header">
      <div style="display:flex;align-items:center;gap:10px;">
        <div class="nav__logo-mark" style="width:32px;height:32px;font-size:14px;flex-shrink:0;">T</div>
        <h1 class="page__title" style="margin:0;">Sign in</h1>
      </div>
      <p style="font-size:13px;color:var(--color-text-muted);margin-top:6px;">Welcome back.</p>
    </div>

    <%= form_with url: session_path, class: "form" do |form| %>
      <div class="form__field">
        <%= form.label :email_address, "Email address", class: "form__label" %>
        <%= form.email_field :email_address, class: "form__input",
            placeholder: "you@example.com",
            autocomplete: "email",
            autofocus: true,
            value: params[:email_address] %>
      </div>

      <div class="form__field">
        <%= form.label :password, "Password", class: "form__label" %>
        <%= form.password_field :password, class: "form__input",
            placeholder: "Your password",
            autocomplete: "current-password",
            maxlength: 72 %>
      </div>

      <div class="form__actions" style="flex-direction:column;gap:12px;">
        <%= form.submit "Sign in", class: "btn btn--primary", style: "width:100%;justify-content:center;" %>
        <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--color-text-muted);">
          <%= link_to "Forgot password?", new_password_path %>
          &nbsp;·&nbsp;
          <%= link_to "Create account", new_registration_path %>
        </div>
      </div>
    <% end %>

    <div style="margin-top:16px;">
      <div style="font-size:12px;color:var(--color-text-muted);margin-bottom:12px;display:flex;align-items:center;gap:8px;">
        <span style="flex:1;height:1px;background:var(--hcp-border-light);"></span>
        또는
        <span style="flex:1;height:1px;background:var(--hcp-border-light);"></span>
      </div>
      <%= button_to "/auth/google_oauth2", method: :post,
            class: "btn btn--secondary",
            style: "width:100%;justify-content:center;gap:8px;" do %>
        <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0;">
          <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
          <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853"/>
          <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
          <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
        </svg>
        Google로 로그인
      <% end %>
      <%= button_to "/auth/naver", method: :post,
            class: "btn btn--secondary",
            style: "width:100%;justify-content:center;gap:8px;margin-top:8px;background:#03C75A;color:#fff;border-color:#03C75A;" do %>
        <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0;">
          <path d="M16.273 12.845L7.376 0H0v24h7.727V11.155L16.624 24H24V0h-7.727z" fill="#fff"/>
        </svg>
        네이버로 로그인
      <% end %>
    </div>
  </div>

  <%# PWA 홈 화면 추가 안내 %>
  <div class="pwa-install-banner"
       data-pwa-install-target="banner">

    <div class="pwa-install-banner__header">
      <i class="fa-solid fa-mobile-screen-button" style="color:var(--color-accent);"></i>
      <span>홈 화면에 추가하기</span>
      <button class="pwa-install-banner__close"
              data-action="click->pwa-install#dismiss"
              aria-label="닫기">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <%# iOS 안내 %>
    <div data-pwa-install-target="iosGuide" hidden>
      <p class="pwa-install-banner__desc">iPhone / iPad (Safari)</p>
      <ol class="pwa-install-banner__steps">
        <li>하단의 <strong>공유 버튼</strong> <i class="fa-solid fa-arrow-up-from-bracket"></i> 탭</li>
        <li><strong>홈 화면에 추가</strong> 선택</li>
        <li><strong>추가</strong> 버튼 탭</li>
      </ol>
      <p class="pwa-install-banner__note">Safari 브라우저에서만 지원됩니다.</p>
    </div>

    <%# Android 안내 %>
    <div data-pwa-install-target="androidGuide" hidden>
      <p class="pwa-install-banner__desc">Android</p>
      <button class="btn btn--primary pwa-install-banner__btn"
              data-pwa-install-target="installBtn"
              data-action="click->pwa-install#install"
              hidden>
        <i class="fa-solid fa-plus"></i> 홈 화면에 추가
      </button>
      <ol class="pwa-install-banner__steps">
        <li>브라우저 우측 상단 <strong>메뉴(⋮)</strong> 탭</li>
        <li><strong>홈 화면에 추가</strong> 또는 <strong>앱 설치</strong> 선택</li>
        <li><strong>설치</strong> 버튼 탭</li>
      </ol>
    </div>

    <%# PC(Desktop Chrome/Edge) 안내 %>
    <div data-pwa-install-target="desktopGuide" hidden>
      <p class="pwa-install-banner__desc">PC (Chrome / Edge)</p>
      <button class="btn btn--primary pwa-install-banner__btn"
              data-pwa-install-target="installBtn"
              data-action="click->pwa-install#install"
              hidden>
        <i class="fa-solid fa-download"></i> 앱으로 설치
      </button>
      <p class="pwa-install-banner__note">
        주소창 우측의 <i class="fa-solid fa-circle-plus"></i> 아이콘을 클릭해도 설치할 수 있습니다.
      </p>
    </div>
  </div>
</div>
