<div class="auth-container">
  <div class="auth-logo">
    <div class="auth-logo__mark">T</div>
  </div>

  <h1 class="auth-title">다시 오셨군요</h1>
  <p class="auth-subtitle">MyTechInfo에 로그인하세요</p>

  <%= form_with url: session_path, class: "auth-form" do |form| %>
    <div class="auth-field">
      <%= form.label :email_address, "이메일", class: "auth-field__label" %>
      <%= form.email_field :email_address,
          class: "auth-field__input",
          placeholder: "you@example.com",
          autocomplete: "email",
          autofocus: true,
          value: params[:email_address] %>
    </div>

    <div class="auth-field">
      <%= form.label :password, "비밀번호", class: "auth-field__label" %>
      <%= form.password_field :password,
          class: "auth-field__input",
          placeholder: "••••••••",
          autocomplete: "current-password",
          maxlength: 72 %>
      <div class="auth-field__hint">
        <%= link_to "비밀번호를 잊으셨나요?", new_password_path, class: "auth-link" %>
      </div>
    </div>

    <%= form.submit "로그인", class: "auth-btn auth-btn--primary" %>
  <% end %>

  <div class="auth-divider"><span>또는</span></div>

  <%= button_to "/auth/google_oauth2", method: :post,
        class: "auth-btn auth-btn--social",
        data: { turbo: false } do %>
    <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
      <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853"/>
      <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
      <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
    </svg>
    Google로 계속하기
  <% end %>

  <%= button_to "/auth/naver", method: :post,
        class: "auth-btn auth-btn--naver",
        data: { turbo: false } do %>
    <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M16.273 12.845L7.376 0H0v24h7.727V11.155L16.624 24H24V0h-7.727z" fill="#fff"/>
    </svg>
    네이버로 계속하기
  <% end %>

  <p class="auth-footer">
    계정이 없으신가요?
    <%= link_to "회원가입", new_registration_path, class: "auth-link auth-link--accent" %>
  </p>
</div>
