<% content_for :title, "Sign Up" %>

<div class="page page--narrow">
  <div class="auth-card">
    <div class="auth-card__header">
      <div style="display:flex;align-items:center;gap:10px;">
        <div class="nav__logo-mark" style="width:32px;height:32px;font-size:14px;flex-shrink:0;">T</div>
        <h1 class="page__title" style="margin:0;">Create your account</h1>
      </div>
      <p style="font-size:13px;color:var(--color-text-muted);margin-top:6px;">Join my site today.</p>
    </div>

    <%= form_with model: @user, url: registration_path, class: "form" do |form| %>
      <% if @user.errors.any? %>
        <div class="form__errors">
          <div class="form__errors-title">
            <%= pluralize(@user.errors.count, "error") %> prevented sign up:
          </div>
          <ul class="form__errors-list">
            <% @user.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form__field">
        <%= form.label :email_address, "Email address", class: "form__label" %>
        <%= form.email_field :email_address, class: "form__input",
            placeholder: "you@example.com",
            autocomplete: "email",
            autofocus: true %>
      </div>

      <div class="form__field">
        <%= form.label :nickname, "Nickname", class: "form__label" %>
        <%= form.text_field :nickname, class: "form__input",
            placeholder: "Nickname (2~30자)",
            autocomplete: "nickname",
            maxlength: 30 %>
      </div>

      <div class="form__field">
        <%= form.label :password, "Password", class: "form__label" %>
        <%= form.password_field :password, class: "form__input",
            placeholder: "Minimum 8 characters",
            autocomplete: "new-password" %>
      </div>

      <div class="form__field">
        <%= form.label :password_confirmation, "Confirm password", class: "form__label" %>
        <%= form.password_field :password_confirmation, class: "form__input",
            placeholder: "Repeat your password",
            autocomplete: "new-password" %>
      </div>

      <div class="form__actions" style="flex-direction:column;gap:12px;">
        <%= form.submit "Create account", class: "btn btn--primary", style: "width:100%;justify-content:center;" %>
        <p style="font-size:12px;color:var(--color-text-muted);text-align:center;">
          Already have an account? <%= link_to "Sign in", new_session_path %>
        </p>
      </div>
    <% end %>
  </div>
</div>
